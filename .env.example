# Backend service config
SERVICE_NAME=friday

# Choose which index you consider "default" internally if you add logic later
INDEX_CHOICE=faiss   # or "s3"

# S3 / AWS (only needed when you actually wire S3 ingestion)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Copy to .env (same folder as your repo root)
APP_NAME=Friday
# Future knobs (not used yet, here for clarity):
# INDEX_DEFAULT=both

# Point the frontend at your live backend.
# Use your own URL here:
VITE_API_BASE=https://friday-o99e.onrender.com/api

# Frontend uses this in dev via vite.config.js proxy
VITE_API_BASE=http://localhost:8000

# Backend needs these
OPENAI_API_KEY=sk-...
REDIS_URL=redis://localhost:6379/0
PICOVOICE_ACCESS_KEY=your_picovoice_key  # (for later, wake word)
